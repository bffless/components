{
  "name": "@bffless/components",
  "version": "0.11.0",
  "description": "Hooks and headless React primitives that the BFFless site templates use under the hood — token URLs, scene rotation, photo capture, posting flows.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./bffless/scheduling/schemas.json": "./bffless/scheduling/schemas.json",
    "./bffless/scheduling/pipelines.json": "./bffless/scheduling/pipelines.json"
  },
  "files": [
    "dist",
    "bffless"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "qrcode.react": {
      "optional": true
    }
  },
  "dependencies": {
    "qrcode.react": "^4.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bffless/components.git"
  },
  "keywords": [
    "bffless",
    "react",
    "hooks",
    "components",
    "wall",
    "guest-wall",
    "celebration"
  ],
  "author": "BFFLESS",
  "license": "O'Saasy",
  "sideEffects": false
}
